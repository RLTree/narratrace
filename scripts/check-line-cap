#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
skill_dir="$(cd "${script_dir}/.." && pwd)"

violations="$(
  find "${skill_dir}" \
    -path '*/target/*' -prune -o \
    -path '*/cargo-target/*' -prune -o \
    -path '*/.codex-worktree/*' -prune -o \
    -path '*/validation_artifacts/*' -prune -o \
    -type f \( \
      -name '*.rs' -o \
      -name '*.sh' -o \
      -path '*/scripts/*' -o \
      -name '*.json' -o \
      -name 'SKILL.md' -o \
      -name 'AGENT_STANDARDS.md' -o \
      -name 'enforcement.tsv' -o \
      -name 'enforcement-audit.tsv' -o \
      -path '*/agent-standards/*.md' -o \
      -name '*.md' \
    \) -print0 |
    grep -zv '/Cargo.lock$' |
    xargs -0 wc -l |
    awk '$2 != "total" && $1 > 250 { print }'
)"

if [[ -n "${violations}" ]]; then
  echo "hand-authored source/skill/standards/docs exceed 250 lines:" >&2
  echo "${violations}" >&2
  exit 1
fi
