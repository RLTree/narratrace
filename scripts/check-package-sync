#!/usr/bin/env bash
set -euo pipefail

if [[ "$#" -ne 2 ]]; then
  echo "usage: check-package-sync <installed-plugin-root> <cache-plugin-root>" >&2
  exit 2
fi

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
skill_dir="$(cd "${script_dir}/.." && pwd)"
installed_root="$1"
cache_root="$2"
status=0

check_empty_rsync_plan() {
  local label="$1"
  shift
  local plan
  plan="$(rsync -aniO --delete "$@")"
  if [[ -n "${plan}" ]]; then
    echo "package sync drift for ${label}:" >&2
    echo "${plan}" >&2
    status=1
  fi
}

core_excludes=(
  --exclude .codex
  --exclude .codex-worktree
  --exclude target
  --exclude cargo-target
  --exclude plugin-skills
  --exclude validation_artifacts
  --exclude COMPLETION_MANIFEST.json
  --exclude VERIFICATION_BACKLOG.json
  --exclude LANE_REGISTRY.json
  --exclude AMENDMENTS.jsonl
  --exclude QUALITY_SCORE.md
)

for root in "${installed_root}" "${cache_root}"; do
  test -d "${root}/skills/narrated-record-replay" || {
    echo "missing packaged core skill: ${root}" >&2
    status=1
    continue
  }
  check_empty_rsync_plan \
    "${root}/skills/narrated-record-replay" \
    "${core_excludes[@]}" \
    "${skill_dir}/" \
    "${root}/skills/narrated-record-replay/"

  for companion in "${skill_dir}/plugin-skills"/*; do
    test -d "${companion}" || continue
    name="$(basename "${companion}")"
    test -d "${root}/skills/${name}" || {
      echo "missing packaged companion skill: ${root}/skills/${name}" >&2
      status=1
      continue
    }
    check_empty_rsync_plan \
      "${root}/skills/${name}" \
      "${companion}/" \
      "${root}/skills/${name}/"
  done
done

exit "${status}"
